{
  "expo": {
    "name": "Yottascore",
    "slug": "Exam-frontend",
    "version": "1.0.10",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "examfrontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "sdkVersion": "54.0.0",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "usesCleartextTraffic": true,
      "permissions": [
        "ACCESS_NETWORK_STATE",
        "INTERNET"
      ],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "package": "com.yottascore.closedbook",
      "versionCode": 16,
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.anonymous.Examfrontend"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "./plugins/withBlockedMediaPermissions.js",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Yottascore to access your photos to upload profile pictures and posts.",
          "cameraPermission": "Allow Yottascore to access your camera to take photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7ce3ecc1-72b6-4ca2-92c3-536276d0396d"
      }
    }
  }
}
